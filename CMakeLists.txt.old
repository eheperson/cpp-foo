# Change version of the cmake accorting of your   <REQUIRED>
cmake_minimum_required(VERSION 3.21.3 FATAL_ERROR)

# Do not forget update the compiler path <REQUIRED>
# set(CMAKE_C_COMPILER "/usr/bin/gcc")
# set(CMAKE_CXX_COMPILER "/usr/bin/g++")
add_definitions(-std=c++11)

# Specify C++ standards
# C++ standards declerations must be above the call to add_executable
set(CMAKE_CXX_STANDARD 11)
set(CMAKE_CXX_STANDARD_REQUIRED True)

# SOME SETTINGS
set(CMAKE_BUILD_TYPE Debug)

# Set some required variables 
set(MODULES_DIR ${CMAKE_SOURCE_DIR}/modules)
set(MODULES_LIST "")
set(MODULES_NAME_LIST "")

# set the project name with version
# ${PROJECT_NAME}
project(cppFoo VERSION 1.0.0)


# Configure the header file to passs the version number to the source code
configure_file(cppFooConfig.h.in cppFooConfig.h)

# add the executable
add_executable(${PROJECT_NAME} main.cpp)

# make the 'xxx' library optional
# this option will be displayed in the cmake-gui and ccmake with a default value of ON
option(BUILD_SDL "Build cpp stl module tutorial files" ON)
option(BUILD_FILEOPERATIONS "Build cpp file operations module tutorial files" ON)
option(BUILD_CONSTKEYWORD "Build cpp const keyword module tutorial files" ON)

if(BUILD_SDL)
    add_subdirectory(${MODULES_DIR}/stl)
    # add_executable(stl ${MODULES_DIR}/stl/main.cpp)
    set(STL_SRC ${MODULES_DIR}/stl/main.cpp)
    list(APPEND MODULES_LIST ${STL_SRC})
    set(STL_MODULE_NAME "stl")
    list(APPEND MODULES_NAME_LIST ${STL_MODULE_NAME})
    list(APPEND EXTRA_INCLUDES "${PROJECT_SOURCE_DIR}/modules")
endif()

if(BUILD_FILEOPERATIONS)
    add_subdirectory(${MODULES_DIR}/fileOperations)
    # add_executable(fileOperations ${MODULES_DIR}/fileOperations/main.cpp)
    set(FILEOPERATIONS_SRC ${MODULES_DIR}/fileOperations/main.cpp)
    list(APPEND MODULES_LIST ${FILEOPERATIONS_SRC})
    set(FILEOPERATIONS_MODULE_NAME "fileOperations")
    list(APPEND MODULES_NAME_LIST ${FILEOPERATIONS_MODULE_NAME})
    list(APPEND EXTRA_INCLUDES "${PROJECT_SOURCE_DIR}/modules")
endif()

if(BUILD_CONSTKEYWORD)
    add_subdirectory(${MODULES_DIR}/constKeyword)
    # add_executable(constKeyword ${MODULES_DIR}/constKeyword/main.cpp)
    set(CONSTKEYWORD_SRC ${MODULES_DIR}/constKeyword/main.cpp)
    list(APPEND MODULES_LIST ${CONSTKEYWORD_SRC})
    set(CONSTKEYWORD_MODULE_NAME "constKeyword")
    list(APPEND MODULES_NAME_LIST ${CONSTKEYWORD_MODULE_NAME})
    list(APPEND EXTRA_INCLUDES "${PROJECT_SOURCE_DIR}/modules")
endif()


# add the binary tree to the search path for include files
# so that we will find exampleLib.h
# (paths to search for include files)
target_include_directories(${PROJECT_NAME} PUBLIC "${PROJECT_BINARY_DIR}")


list(LENGTH MODULES_LIST lenModulesList)
math(EXPR lenModulesNameList "${lenModulesList} - 1")
foreach(i RANGE ${lenModulesNameList})
    list(GET MODULES_LIST ${i} modulesIndex)
    list(GET MODULES_NAME_LIST ${i} modulesNameIndex)
    message(STATUS "${modulesNameIndex}  --  ${modulesIndex}")
    add_executable(${modulesNameIndex} ${modulesIndex})
endforeach()

